# ===========================================
# Configuración de Ambiente
# ===========================================

# Ambiente de ejecución (development, staging, production)
NODE_ENV=development

# ===========================================
# URLs de la Aplicación
# ===========================================

# URL base del frontend
BASE_URL=http://localhost:3000

# URL base de la API
API_URL=http://localhost:3000/api

# ===========================================
# Base de Datos - PostgreSQL
# ===========================================

# Configuración PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password
PG_DATABASE=test_db
PG_SSL=false

# ===========================================
# Base de Datos - SQL Server
# ===========================================

# Configuración SQL Server
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=your_password
MSSQL_DATABASE=test_db
MSSQL_ENCRYPT=false

# ===========================================
# Base de Datos - MySQL
# ===========================================

# Configuración MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=test_db

# ===========================================
# Credenciales de Prueba
# ===========================================

# Usuario de prueba
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=TestPassword123!

# Usuario administrador
ADMIN_USER_EMAIL=admin@example.com
ADMIN_USER_PASSWORD=AdminPassword123!

# ===========================================
# API Keys y Tokens
# ===========================================

# Token de autenticación para API
API_TOKEN=your_api_token_here

# ===========================================
# Configuración de CI/CD
# ===========================================

# Flag para CI
CI=false

# ===========================================
# Kafka - Configuración de Brokers
# ===========================================

# Lista de brokers separados por coma
KAFKA_BROKERS=localhost:9092

# Group ID para el consumidor
KAFKA_GROUP_ID=playwright-test-group

# Client ID
KAFKA_CLIENT_ID=playwright-tests

# ===========================================
# Kafka - Seguridad (opcional)
# ===========================================

# Habilitar SSL
KAFKA_SSL=false

# Mecanismo SASL (plain, scram-sha-256, scram-sha-512)
KAFKA_SASL_MECHANISM=plain

# Credenciales SASL
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ===========================================
# Kafka - Topics
# ===========================================

# Topic para eventos de usuario
KAFKA_TOPIC_USER_EVENTS=user-events

# Topic para eventos de órdenes
KAFKA_TOPIC_ORDER_EVENTS=order-events

# Topic para eventos de productos
KAFKA_TOPIC_PRODUCT_EVENTS=product-events

# Topic para log de auditoría
KAFKA_TOPIC_AUDIT_LOG=audit-log

# Topic para estado de cotizaciones (Quotations API)
KAFKA_TOPIC_QUOTATION_STATUS=apm0005763.bsn0019380.latam.sit.status.process.v1

# ===========================================
# Quotations API (LATAM)
# ===========================================

# URL del endpoint de Quotations
QUOTATIONS_API_URL=http://LAUSD-WPIP001.aceins.com:4443/api/Quotations

# Token Bearer para autenticación
QUOTATIONS_API_TOKEN=your_bearer_token_here
